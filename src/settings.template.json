{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "skillListingBudgetFraction": 0.05,
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          { "type": "command", "command": "node $CLAUDE_PROJECT_DIR/.claude/hooks/destructive_cmd_guard.mjs" },
          { "type": "command", "command": "node $CLAUDE_PROJECT_DIR/.claude/hooks/git_commit_guard.mjs" },
          { "type": "command", "command": "node $CLAUDE_PROJECT_DIR/.claude/hooks/gitignore_leak_guard.mjs" },
          { "type": "command", "command": "node $CLAUDE_PROJECT_DIR/.claude/hooks/process_lifecycle_guard.mjs" }
        ]
      },
      {
        "matcher": "Write|Edit|MultiEdit|NotebookEdit",
        "hooks": [
          { "type": "command", "command": "node $CLAUDE_PROJECT_DIR/.claude/hooks/setup_guard.mjs" },
          { "type": "command", "command": "node $CLAUDE_PROJECT_DIR/.claude/hooks/env_guard.mjs" },
          { "type": "command", "command": "node $CLAUDE_PROJECT_DIR/.claude/hooks/spec_approval_guard.mjs" },
          { "type": "command", "command": "node $CLAUDE_PROJECT_DIR/.claude/hooks/swarm_approval_guard.mjs" },
          { "type": "command", "command": "node $CLAUDE_PROJECT_DIR/.claude/hooks/epic_approval_guard.mjs" },
          { "type": "command", "command": "node $CLAUDE_PROJECT_DIR/.claude/hooks/git_commit_guard.mjs" },
          { "type": "command", "command": "node $CLAUDE_PROJECT_DIR/.claude/hooks/verify_pass_guard.mjs" },
          { "type": "command", "command": "node $CLAUDE_PROJECT_DIR/.claude/hooks/track_guard.mjs" },
          { "type": "command", "command": "node $CLAUDE_PROJECT_DIR/.claude/hooks/artifact_template_guard.mjs" },
          { "type": "command", "command": "node $CLAUDE_PROJECT_DIR/.claude/hooks/plantuml_syntax_guard.mjs" },
          { "type": "command", "command": "node $CLAUDE_PROJECT_DIR/.claude/hooks/spec_diagram_presence_guard.mjs" },
          { "type": "command", "command": "node $CLAUDE_PROJECT_DIR/.claude/hooks/swarm_boundary_guard.mjs" },
          { "type": "command", "command": "node $CLAUDE_PROJECT_DIR/.claude/hooks/spec_design_calls_guard.mjs" }
        ]
      },
      {
        "matcher": "Write",
        "hooks": [
          { "type": "command", "command": "node $CLAUDE_PROJECT_DIR/.claude/hooks/tdd_order_guard.mjs" }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          { "type": "command", "command": "node $CLAUDE_PROJECT_DIR/.claude/hooks/consent_gate_grant.mjs" }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit|MultiEdit",
        "hooks": [
          { "type": "command", "command": "node $CLAUDE_PROJECT_DIR/.claude/hooks/lint_runner.mjs" },
          { "type": "command", "command": "node $CLAUDE_PROJECT_DIR/.claude/hooks/test_runner.mjs" }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          { "type": "command", "command": "node $CLAUDE_PROJECT_DIR/.claude/hooks/memory_session_start.mjs" }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          { "type": "command", "command": "node $CLAUDE_PROJECT_DIR/.claude/hooks/memory_stop.mjs" },
          { "type": "command", "command": "node $CLAUDE_PROJECT_DIR/.claude/hooks/harness_continuation.mjs" }
        ]
      }
    ],
    "PreCompact": [
      {
        "matcher": "manual|auto",
        "hooks": [
          { "type": "command", "command": "node $CLAUDE_PROJECT_DIR/.claude/hooks/memory_pre_compact.mjs" }
        ]
      }
    ]
  },
  "permissions": {
    "allow": [
      "Read",
      "Bash(ls:*)",
      "Bash(cat:*)",
      "Bash(rg:*)",
      "Bash(grep:*)",
      "Bash(git status:*)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git show:*)",
      "Bash(git branch:*)",
      "Bash(git blame:*)"
    ],
    "deny": [
      "Bash(git commit --amend:*)",
      "Bash(git reset --hard:*)",
      "Bash(git clean -f:*)",
      "Bash(git clean -fd:*)",
      "Bash(git branch -D:*)",
      "Bash(git checkout --:*)",
      "Bash(git config:*)",
      "Bash(git rebase -i:*)",
      "Bash(git add -A:*)",
      "Bash(git add .:*)",
      "Edit(.env)",
      "Edit(.env.*)",
      "Write(.env)",
      "Write(.env.*)"
    ]
  }
}
