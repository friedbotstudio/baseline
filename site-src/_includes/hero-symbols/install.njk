{# Install hero symbol — the drop.
   An open frame represents the target project root. Four filled-ink rects
   land inside, labelled with mono caps for the four sentinel paths the CLI
   writes (`.claude`, `CLAUDE.md`, `.mcp.json`, `seed.md`). A single accent
   dot above marks the moment of install. Vocabulary: open frame = target,
   filled ink = sentinel, accent dot = install action, mono caps caption. #}
<svg class="hero-symbol-svg dropbox-svg" viewBox="0 0 360 360" xmlns="http://www.w3.org/2000/svg" role="img" aria-labelledby="dropbox-title">
  <title id="dropbox-title">Four sentinel paths drop into the target project on install.</title>

  {# Install action — accent dot above the frame. #}
  <circle class="db-action" cx="180" cy="38" r="6.5"/>
  <line   class="db-drop"   x1="180" y1="50" x2="180" y2="84"/>

  {# Target project — open frame. #}
  <rect class="db-target" x="40" y="92" width="280" height="208" rx="8"/>
  <text class="db-target-tag" x="55" y="120">~/your-project</text>

  {# Four sentinel paths — filled-ink rects with mono caps labels. #}
  <g class="db-sentinel">
    <rect x="64"  y="148" width="232" height="32" rx="4"/>
    <text class="db-label on-fill" x="80" y="169">.claude/</text>
  </g>
  <g class="db-sentinel">
    <rect x="64"  y="190" width="232" height="32" rx="4"/>
    <text class="db-label on-fill" x="80" y="211">CLAUDE.md</text>
  </g>
  <g class="db-sentinel">
    <rect x="64"  y="232" width="232" height="32" rx="4"/>
    <text class="db-label on-fill" x="80" y="253">.mcp.json</text>
  </g>
  <g class="db-sentinel">
    <rect x="64"  y="274" width="232" height="14" rx="3"/>
    <text class="db-label-mini on-fill" x="80" y="285">docs/init/seed.md</text>
  </g>

  {# Caption. #}
  <text class="db-caption" x="180" y="326" text-anchor="middle">one command · four sentinel paths</text>
</svg>
