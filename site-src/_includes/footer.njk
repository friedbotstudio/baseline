<footer class="site">
  <div class="footer-inner">
    <div class="footer-grid">
      <div class="footer-brand-col">
        <a class="brand" href="{{ '/' | rel }}">
          <span class="dot"></span><span>{{ site.brand }}</span>
        </a>
        <p class="footer-tagline">{{ site.tagline }}</p>
        <p class="footer-attribution">Product of <a href="https://friedbotstudio.com">Friedbot Studio Private Limited</a></p>
      </div>
      <div class="footer-col">
        <h5>Docs</h5>
        <ul>
          <li><a href="{{ '/hooks/' | rel }}">Hooks</a></li>
          <li><a href="{{ '/memory/' | rel }}">Memory</a></li>
          <li><a href="{{ '/swarm/' | rel }}">Swarm mode</a></li>
          <li><a href="{{ '/skills/' | rel }}">Skills</a></li>
        </ul>
      </div>
      <div class="footer-col">
        <h5>Project</h5>
        <ul>
          <li><a href="{{ site.repo }}">GitHub</a></li>
          <li><a href="{{ site.repo }}/blob/main/CLAUDE.md">Constitution</a></li>
          <li><a href="{{ site.repo }}/blob/main/LICENSE">License</a></li>
          <li><a href="{{ site.repo }}/issues">Issues</a></li>
        </ul>
      </div>
    </div>
    <div class="footer-meta-row">
      <span>© {{ site.year }} {{ site.brand }} · Apache 2.0-licensed</span>
      <span>{{ site.version }} · updated {{ site.lastUpdated }} · build {{ build.build_id }}</span>
    </div>
  </div>
</footer>
