function CopyButton({ text }) {
  const [state, setState] = useState("");
  const onClick = useCallback(async () => {
    try { await navigator.clipboard.writeText(text); }
    catch (_) {
      const ta = document.createElement("textarea");
      ta.value = text; ta.style.position = "fixed"; ta.style.opacity = "0";
      document.body.appendChild(ta); ta.select();
      try { document.execCommand("copy"); } catch (_) {}
      document.body.removeChild(ta);
    }
    setState("copied");
    setTimeout(() => setState(""), 1600);
  }, [text]);

  return (
    <button
      type="button"
      className="copy-btn"
      data-state={state || undefined}
      onClick={onClick}
      aria-label={state === "copied" ? "Copied to clipboard" : "Copy to clipboard"}
    >
      <svg viewBox="0 0 16 16" fill="none" stroke="currentColor" strokeWidth="1.4" strokeLinecap="round" strokeLinejoin="round" aria-hidden="true">
        <rect x="4.5" y="4.5" width="8" height="9" rx="1.2" />
        <path d="M3 11V3.5A1.5 1.5 0 0 1 4.5 2H11" />
      </svg>
      <span>{state === "copied" ? "Copied" : "Copy"}</span>
    </button>
  );
}

// ============================================================ SCROLL SPY ============================================================
function useScrollSpy(ids) {
  const [activeId, setActiveId] = useState(ids[0] || "");
  const visibleRef = useRef(new Set());

  useEffect(() => {
    if (!ids.length) return;
    const elements = ids
      .map((id) => document.getElementById(id))
      .filter(Boolean);
    if (!elements.length) return;

    visibleRef.current = new Set();
    const observer = new IntersectionObserver(
      (entries) => {
        for (const entry of entries) {
          if (entry.isIntersecting) visibleRef.current.add(entry.target.id);
          else visibleRef.current.delete(entry.target.id);
        }
        const visibleInOrder = ids.filter((id) => visibleRef.current.has(id));
        if (visibleInOrder.length) setActiveId(visibleInOrder[0]);
      },
      { rootMargin: "-120px 0px -55% 0px", threshold: 0 }
    );
    for (const el of elements) observer.observe(el);
    return () => observer.disconnect();
  }, [ids.join("|")]);

  return activeId;
}

// ============================================================ TOPNAV ============================================================
// Right-side: version label + GitHub icon. Section navigation lives in the
// sidebar, not the topnav, so the topnav stays minimal and identity-focused.
function GithubIcon() {
  return (
    <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
      <path d="M12 .5C5.65.5.5 5.65.5 12c0 5.08 3.29 9.39 7.86 10.91.58.11.79-.25.79-.55 0-.27-.01-1-.02-1.96-3.2.7-3.87-1.54-3.87-1.54-.52-1.32-1.27-1.67-1.27-1.67-1.04-.71.08-.7.08-.7 1.15.08 1.76 1.18 1.76 1.18 1.02 1.75 2.68 1.24 3.34.95.1-.74.4-1.24.73-1.53-2.55-.29-5.23-1.27-5.23-5.66 0-1.25.45-2.27 1.18-3.07-.12-.29-.51-1.45.11-3.02 0 0 .96-.31 3.15 1.17a10.94 10.94 0 0 1 5.74 0c2.19-1.48 3.15-1.17 3.15-1.17.62 1.57.23 2.73.11 3.02.74.8 1.18 1.82 1.18 3.07 0 4.4-2.69 5.37-5.25 5.66.41.35.78 1.05.78 2.12 0 1.53-.01 2.76-.01 3.13 0 .31.21.67.8.55C20.71 21.39 24 17.08 24 12 24 5.65 18.85.5 12 .5z"/>
    </svg>
  );
}

function Topnav() {
  return (
    <header className="topnav">
      <div className="topnav-inner">
        <a href="#top" className="brand" aria-label="baseline — home">
          <img
            src="assets/brandmark.png"
            srcSet="assets/brandmark.png 1x, assets/brandmark@2x.png 2x"
            width={26}
            height={26}
            alt=""
            className="brand-mark"
            aria-hidden="true"
          />
          <span className="brand-block">
            <span className="brand-name">baseline</span>
            <span className="brand-version">v0.1</span>
          </span>
          <span className="brand-meta">for Agentic Coding</span>
        </a>
        <span className="topnav-spacer" />
        <a
          href="https://github.com/friedbotstudio/baseline"
          target="_blank"
          rel="noopener"
          className="topnav-btn"
          aria-label="GitHub repository: friedbotstudio/baseline"
        >
          <GithubIcon />
          <span>friedbotstudio/baseline</span>
        </a>
      </div>
    </header>
  );
}

// ============================================================ SIDEBAR ============================================================
function Sidebar({ activeSectionId }) {
  return (
    <aside className="sidebar" aria-label="Page navigation">
      <div className="side-section">
        <p className="side-title">Get oriented</p>
        {SECTIONS.map((s) => (
          <a
            key={s.id}
            href={`#${s.id}`}
            className={`side-link${activeSectionId === s.id ? " active" : ""}`}
          >
            <span className="num">{s.num}</span>
            <span className="label">{s.label}</span>
          </a>
        ))}
      </div>

      <div className="side-section">
        <p className="side-title">At a glance</p>
        {GLANCE.map((g) => (
          <a key={g.label} href={g.href} className="side-link">
            <span className="label">{g.label}</span>
            <span className="tag">{g.tag}</span>
          </a>
        ))}
      </div>
    </aside>
  );
}

// ============================================================ TOC ============================================================
function TOC({ activeId }) {
  return (
    <nav className="toc" aria-label="On this page">
      <p className="toc-title">On this page</p>
      {TOC_TREE.map((node) => (
        <React.Fragment key={node.id}>
          <a
            href={`#${node.id}`}
            className={`toc-link${activeId === node.id ? " active" : ""}`}
          >
            {node.label}
          </a>
          {node.children?.map((c) => (
            <a
              key={c.id}
              href={`#${c.id}`}
              className={`toc-link l2${activeId === c.id ? " active" : ""}`}
            >
              {c.label}
            </a>
          ))}
        </React.Fragment>
      ))}
    </nav>
  );
}

// ============================================================ HERO CHIP ============================================================
function HeroChip() {
  return (
    <p className="hero-chip" aria-label="Status">
      <span className="dot" />
      <span>audit-baseline</span>
      <span className="sep">·</span>
      <span>70+ checks pass</span>
      <span className="sep">·</span>
      <span>2026-04-28</span>
    </p>
  );
}

// ============================================================ PIPELINE SUBWAY ============================================================
const PIPELINE_PHASES = [
  { x: 20,  label: "intake"    },
  { x: 82,  label: "scout"     },
  { x: 144, label: "research"  },
  { x: 206, label: "spec"      },
  { x: 280, label: "tdd"       },
  { x: 342, label: "simplify"  },
  { x: 404, label: "security"  },
  { x: 466, label: "integrate" },
  { x: 528, label: "document"  },
  { x: 590, label: "archive"   },
  { x: 664, label: "commit"    },
];

// Mobile vertical layout — same architecture (11 phases, 2 main gates, swarm
// side-rail with /approve-swarm gate, retry arc) but oriented top-to-bottom so
// labels stay legible at <=480px viewports. Rendered alongside the desktop
// horizontal version; CSS toggles which is visible by viewport width.
function PipelineSubwayMobile() {
  const W = 320;
  const phaseW = 200, phaseH = 28;
  const phaseX = 60;
  const phaseStride = 36;
  const gateRow = 30;

  // Build rows top-to-bottom: phases with 2 gates inserted after spec (idx 3)
  // and after archive (idx 9). Swarm side-rail sits between phase-5 (tdd) and
  // phase-6 (simplify), drawn as a small indented sub-tree on the right.
  const phases = [
    "intake", "scout", "research", "spec",
    "tdd", "simplify", "security", "integrate",
    "document", "archive", "commit",
  ];

  // Compute y-positions:
  //   phase-row: phaseStride
  //   gate row before tdd: +gateRow extra
  //   side-rail block between tdd and simplify: +120 (3 cells + connectors)
  //   gate row before commit: +gateRow extra
  let y = 16;
  const rows = [];
  phases.forEach((label, i) => {
    rows.push({ kind: "phase", label, num: String(i + 1).padStart(2, "0"), y });
    y += phaseStride;
    if (i === 3) {
      rows.push({ kind: "gate", label: "/approve-spec", y });
      y += gateRow;
    }
    if (i === 4) {
      // After /tdd we draw the swarm side-rail
      rows.push({ kind: "swarm", y });
      y += 120;
    }
    if (i === 9) {
      rows.push({ kind: "gate", label: "/grant-commit", y });
      y += gateRow;
    }
  });
  const totalHeight = y + 30;

  return (
    <div className="subway-wrap-mobile">
      <svg className="subway-svg-mobile" viewBox={`0 0 ${W} ${totalHeight}`} xmlns="http://www.w3.org/2000/svg" role="img" aria-label="Eleven-phase pipeline (vertical mobile layout)">
        <defs>
          <marker id="sub-arr-m" viewBox="0 0 8 8" refX="7" refY="4" markerWidth="5" markerHeight="5" orient="auto">
            <path d="M0 0 L8 4 L0 8 z" fill="var(--color-charcoal)" />
          </marker>
          <marker id="sub-arr-m-dim" viewBox="0 0 8 8" refX="7" refY="4" markerWidth="5" markerHeight="5" orient="auto">
            <path d="M0 0 L8 4 L0 8 z" fill="var(--color-accent-dark)" opacity="0.6" />
          </marker>
        </defs>

        {rows.map((r, idx) => {
          if (r.kind === "phase") {
            return (
              <g key={`p-${idx}`}>
                <text x={phaseX - 8} y={r.y + phaseH / 2 + 3.5} textAnchor="end"
                      fontFamily="ui-monospace, monospace"
                      fontSize="9.5" fontWeight="600" fill="var(--color-ash)">
                  {r.num}
                </text>
                <rect x={phaseX} y={r.y} width={phaseW} height={phaseH} rx="3"
                      fill="var(--color-paper)" stroke="var(--color-charcoal)" strokeWidth="1" />
                <text x={phaseX + phaseW / 2} y={r.y + phaseH / 2 + 3.5} textAnchor="middle"
                      fontFamily="ui-monospace, monospace"
                      fontSize="11" fontWeight="500" fill="var(--color-ink)">
                  {r.label}
                </text>
                {/* down arrow to next row, unless this is the last phase */}
                {idx < rows.length - 1 && (
                  <line x1={phaseX + phaseW / 2} y1={r.y + phaseH}
                        x2={phaseX + phaseW / 2} y2={r.y + phaseH + 8}
                        stroke="var(--color-charcoal)" strokeWidth="1"
                        markerEnd="url(#sub-arr-m)" />
                )}
              </g>
            );
          }
          if (r.kind === "gate") {
            return (
              <g key={`g-${idx}`}>
                <line x1={phaseX - 8} y1={r.y + 14} x2={phaseX + phaseW + 8} y2={r.y + 14}
                      stroke="var(--color-accent-dark)" strokeWidth="2" />
                <text x={W / 2} y={r.y + 9} textAnchor="middle"
                      fontFamily="ui-monospace, monospace"
                      fontSize="10" fontWeight="700" fill="var(--color-accent-dark)"
                      letterSpacing="0.04em">
                  {r.label}
                </text>
                {/* connector down to next row */}
                <line x1={phaseX + phaseW / 2} y1={r.y + 18}
                      x2={phaseX + phaseW / 2} y2={r.y + 28}
                      stroke="var(--color-charcoal)" strokeWidth="1"
                      markerEnd="url(#sub-arr-m)" />
              </g>
            );
          }
          if (r.kind === "swarm") {
            // Side-rail: 3 stacked cells indented to the right.
            const sideX = 130, sideW = 160, sideH = 24, sideStride = 30;
            const planY = r.y + 6;
            const gateY = planY + sideStride;
            const dispY = gateY + sideStride;
            return (
              <g key={`sw-${idx}`}>
                {/* Branch from main rail (above this y) curving right and down to swarm-plan */}
                <path d={`M ${phaseX + phaseW / 2} ${r.y - 8} V ${planY + sideH / 2} H ${sideX}`}
                      fill="none" stroke="var(--color-charcoal)" strokeWidth="1"
                      strokeDasharray="3 2"
                      markerEnd="url(#sub-arr-m)" />
                {/* swarm-plan */}
                <rect x={sideX} y={planY} width={sideW} height={sideH} rx="3"
                      fill="var(--color-paper)" stroke="var(--color-charcoal)" strokeWidth="1" />
                <text x={sideX + sideW / 2} y={planY + sideH / 2 + 3.5} textAnchor="middle"
                      fontFamily="ui-monospace, monospace"
                      fontSize="10.5" fontWeight="500" fill="var(--color-ink)">
                  swarm-plan
                </text>
                {/* arrow */}
                <line x1={sideX + sideW / 2} y1={planY + sideH}
                      x2={sideX + sideW / 2} y2={planY + sideH + 6}
                      stroke="var(--color-charcoal)" strokeWidth="1"
                      markerEnd="url(#sub-arr-m)" />
                {/* /approve-swarm gate (mini accent line within the side-rail width) */}
                <line x1={sideX - 4} y1={gateY + sideH / 2} x2={sideX + sideW + 4} y2={gateY + sideH / 2}
                      stroke="var(--color-accent-dark)" strokeWidth="2" />
                <text x={sideX + sideW / 2} y={gateY + sideH / 2 - 6} textAnchor="middle"
                      fontFamily="ui-monospace, monospace"
                      fontSize="9.5" fontWeight="700" fill="var(--color-accent-dark)"
                      letterSpacing="0.04em">
                  /approve-swarm
                </text>
                {/* arrow */}
                <line x1={sideX + sideW / 2} y1={gateY + sideH / 2 + 6}
                      x2={sideX + sideW / 2} y2={gateY + sideH / 2 + 18}
                      stroke="var(--color-charcoal)" strokeWidth="1"
                      markerEnd="url(#sub-arr-m)" />
                {/* swarm-dispatch */}
                <rect x={sideX} y={dispY} width={sideW} height={sideH} rx="3"
                      fill="var(--color-paper)" stroke="var(--color-charcoal)" strokeWidth="1" />
                <text x={sideX + sideW / 2} y={dispY + sideH / 2 + 3.5} textAnchor="middle"
                      fontFamily="ui-monospace, monospace"
                      fontSize="10.5" fontWeight="500" fill="var(--color-ink)">
                  swarm-dispatch
                </text>
                {/* Rejoin: from swarm-dispatch curving back left to main rail */}
                <path d={`M ${sideX + sideW / 2} ${dispY + sideH} V ${dispY + sideH + 12} H ${phaseX + phaseW / 2} V ${dispY + sideH + 26}`}
                      fill="none" stroke="var(--color-charcoal)" strokeWidth="1"
                      strokeDasharray="3 2"
                      markerEnd="url(#sub-arr-m)" />
              </g>
            );
          }
          return null;
        })}

        {/* Retry arc — dashed accent-dim curve from /integrate (phase 8) back up to /tdd (phase 5) on the right margin */}
        {(() => {
          const integrateRow = rows.find((r) => r.kind === "phase" && r.label === "integrate");
          const tddRow = rows.find((r) => r.kind === "phase" && r.label === "tdd");
          if (!integrateRow || !tddRow) return null;
          const xRight = phaseX + phaseW + 16;
          const yFrom = integrateRow.y + phaseH / 2;
          const yTo   = tddRow.y + phaseH / 2;
          const peakX = xRight + 18;
          return (
            <g>
              <path d={`M ${phaseX + phaseW + 2} ${yFrom} L ${xRight} ${yFrom} Q ${peakX} ${(yFrom + yTo) / 2}, ${xRight} ${yTo} L ${phaseX + phaseW + 2} ${yTo}`}
                    fill="none"
                    stroke="var(--color-accent-dark)"
                    strokeOpacity="0.55"
                    strokeWidth="1"
                    strokeDasharray="4 3"
                    markerEnd="url(#sub-arr-m-dim)" />
              <text x={xRight + 22} y={(yFrom + yTo) / 2 + 3} textAnchor="start"
                    fontFamily="ui-monospace, monospace"
                    fontSize="9" fontWeight="600" fill="var(--color-accent-dark)"
                    opacity="0.9" letterSpacing="0.06em">
                retry
              </text>
              <text x={xRight + 22} y={(yFrom + yTo) / 2 + 14} textAnchor="start"
                    fontFamily="ui-monospace, monospace"
                    fontSize="9" fontWeight="600" fill="var(--color-accent-dark)"
                    opacity="0.9" letterSpacing="0.06em">
                ≤3
              </text>
            </g>
          );
        })()}
      </svg>
    </div>
  );
}

function PipelineSubway({ inset }) {
  const phaseW = 56, phaseH = 22, mainY = 72;
  const sideY = 160, sideH = 22;

  return (
    <div className={inset ? "subway-wrap inset" : "subway-wrap"}>
      <svg className="subway-svg" viewBox="0 0 740 200" xmlns="http://www.w3.org/2000/svg" role="img" aria-label="Eleven-phase pipeline with three consent gates and a swarm side-rail">
        <defs>
          <marker id="sub-arr" viewBox="0 0 8 8" refX="7" refY="4" markerWidth="5" markerHeight="5" orient="auto">
            <path d="M0 0 L8 4 L0 8 z" fill="var(--color-charcoal)" />
          </marker>
          <marker id="sub-arr-dim" viewBox="0 0 8 8" refX="7" refY="4" markerWidth="5" markerHeight="5" orient="auto">
            <path d="M0 0 L8 4 L0 8 z" fill="var(--color-accent-dark)" opacity="0.6" />
          </marker>
        </defs>

        {/* Retry arc: from /integrate back to /tdd. Dashed, accent-dim. */}
        <path
          d="M 494 72 Q 401 18, 308 72"
          fill="none"
          stroke="var(--color-accent-dark)"
          strokeOpacity="0.55"
          strokeWidth="1"
          strokeDasharray="4 3"
          markerEnd="url(#sub-arr-dim)"
        />
        <text x="401" y="14" textAnchor="middle"
          fontFamily="ui-monospace, monospace"
          fontSize="9.5" fontWeight="600"
          fill="var(--color-accent-dark)"
          opacity="0.85"
          letterSpacing="0.06em"
        >
          retry ≤3
        </text>

        {/* Main rail phase cells */}
        {PIPELINE_PHASES.map((p) => (
          <g key={p.label}>
            <rect
              x={p.x} y={mainY} width={phaseW} height={phaseH}
              rx="3"
              fill="var(--color-paper)"
              stroke="var(--color-charcoal)"
              strokeWidth="1"
            />
            <text
              x={p.x + phaseW / 2}
              y={mainY + phaseH / 2 + 3.5}
              textAnchor="middle"
              fontFamily="ui-monospace, monospace"
              fontSize="9.5"
              fontWeight="600"
              fill="var(--color-ink)"
            >
              {p.label}
            </text>
          </g>
        ))}

        {/* Inter-phase arrows on main rail (skip across gate gaps) */}
        {PIPELINE_PHASES.slice(0, -1).map((p, i) => {
          if (i === 3 || i === 9) return null;
          const next = PIPELINE_PHASES[i + 1];
          return (
            <line
              key={`arr-${i}`}
              x1={p.x + phaseW} y1={mainY + phaseH / 2}
              x2={next.x}        y2={mainY + phaseH / 2}
              stroke="var(--color-charcoal)"
              strokeWidth="1"
              markerEnd="url(#sub-arr)"
            />
          );
        })}

        {/* Gate G1 — /approve-spec */}
        <line x1={262} y1={mainY + phaseH / 2} x2={266} y2={mainY + phaseH / 2}
              stroke="var(--color-charcoal)" strokeWidth="1" />
        <line x1={271} y1={mainY - 4}  x2={271} y2={mainY + phaseH + 4}
              stroke="var(--color-accent-dark)" strokeWidth="2" />
        <line x1={276} y1={mainY + phaseH / 2} x2={280} y2={mainY + phaseH / 2}
              stroke="var(--color-charcoal)" strokeWidth="1" markerEnd="url(#sub-arr)" />
        <text x={271} y={mainY - 12} textAnchor="middle"
              fontFamily="ui-monospace, monospace"
              fontSize="9.5" fontWeight="700"
              fill="var(--color-accent-dark)"
              letterSpacing="0.04em">
          /approve-spec
        </text>

        {/* Gate G2 — /grant-commit */}
        <line x1={646} y1={mainY + phaseH / 2} x2={650} y2={mainY + phaseH / 2}
              stroke="var(--color-charcoal)" strokeWidth="1" />
        <line x1={655} y1={mainY - 4}  x2={655} y2={mainY + phaseH + 4}
              stroke="var(--color-accent-dark)" strokeWidth="2" />
        <line x1={660} y1={mainY + phaseH / 2} x2={664} y2={mainY + phaseH / 2}
              stroke="var(--color-charcoal)" strokeWidth="1" markerEnd="url(#sub-arr)" />
        <text x={655} y={mainY - 12} textAnchor="middle"
              fontFamily="ui-monospace, monospace"
              fontSize="9.5" fontWeight="700"
              fill="var(--color-accent-dark)"
              letterSpacing="0.04em">
          /grant-commit
        </text>

        {/* Side-rail cells */}
        <rect x={185} y={sideY} width={68} height={sideH} rx="3"
              fill="var(--color-paper)" stroke="var(--color-charcoal)" strokeWidth="1" />
        <text x={185 + 34} y={sideY + sideH / 2 + 3.5} textAnchor="middle"
              fontFamily="ui-monospace, monospace"
              fontSize="9.5" fontWeight="600" fill="var(--color-ink)">
          swarm-plan
        </text>

        {/* G3 — /approve-swarm */}
        <line x1={258} y1={sideY + sideH / 2} x2={261} y2={sideY + sideH / 2}
              stroke="var(--color-charcoal)" strokeWidth="1" />
        <line x1={266} y1={sideY - 4} x2={266} y2={sideY + sideH + 4}
              stroke="var(--color-accent-dark)" strokeWidth="2" />
        <line x1={271} y1={sideY + sideH / 2} x2={273} y2={sideY + sideH / 2}
              stroke="var(--color-charcoal)" strokeWidth="1" markerEnd="url(#sub-arr)" />
        <text x={266} y={sideY - 8} textAnchor="middle"
              fontFamily="ui-monospace, monospace"
              fontSize="9" fontWeight="700" fill="var(--color-accent-dark)"
              letterSpacing="0.04em">
          /approve-swarm
        </text>

        <rect x={273} y={sideY} width={98} height={sideH} rx="3"
              fill="var(--color-paper)" stroke="var(--color-charcoal)" strokeWidth="1" />
        <text x={273 + 49} y={sideY + sideH / 2 + 3.5} textAnchor="middle"
              fontFamily="ui-monospace, monospace"
              fontSize="9.5" fontWeight="600" fill="var(--color-ink)">
          swarm-dispatch
        </text>

        {/* Fork from G1 to /swarm-plan */}
        <path
          d="M 271 96 V 130 H 219 V 160"
          fill="none"
          stroke="var(--color-charcoal)"
          strokeWidth="1"
          markerEnd="url(#sub-arr)"
        />

        {/* Rejoin from /swarm-dispatch to P6 (/simplify) */}
        <path
          d="M 371 160 V 130 H 370 V 96"
          fill="none"
          stroke="var(--color-charcoal)"
          strokeWidth="1"
          markerEnd="url(#sub-arr)"
        />

        <text x={278} y={sideY + sideH + 14} textAnchor="middle"
              fontFamily="ui-monospace, monospace"
              fontSize="9" fontWeight="500" fill="var(--color-ash)"
              letterSpacing="0.06em">
          optional · parallel
        </text>
      </svg>
    </div>
  );
}

// ============================================================ MASTHEAD ============================================================
// Bicolor H1 — first phrase ink, second phrase accent-dark on its own line.
// The accent-bearing phrase is the brand: "baseline." The phantomflow pattern
// puts the result/verb of the claim in accent; for a product page where the
// product name IS the claim, the brand carries the accent.
function Masthead() {
  return (
    <div className="masthead" id="top">
      <HeroChip />

      <h1>
        <span className="accent">baseline</span> for Agentic Coding
      </h1>

      <p className="lead">
        Skills run in main context. One subagent handles parallel work in isolated worktrees.
      </p>

      <p className="lead-secondary">
        Most Claude setups bundle capabilities into subagents. Baseline keeps them as skills in the main conversation, so the model still sees the screenshot you pasted three turns ago. The single subagent we kept, <code>swarm-worker</code>, handles parallel code execution in <code>git</code> worktrees where cross-task writes are physically impossible. Judgment work doesn't survive a Task brief.
      </p>

      <div className="magazine-bento" role="group" aria-label="Inventory at a glance">
        <div className="bento-cell">
          <p className="stat-label">Hooks</p>
          <p className="stat-num">16</p>
          <p className="stat-sub">14 guards · 2 lifecycle</p>
        </div>
        <div className="bento-cell">
          <p className="stat-label">Skills</p>
          <p className="stat-num">35</p>
          <p className="stat-sub">across 8 categories</p>
        </div>
        <div className="bento-cell">
          <p className="stat-label">Subagent</p>
          <p className="stat-num">1</p>
          <p className="stat-sub"><code>swarm-worker</code></p>
        </div>

        <div className="bento-cell span-3 subway-cell" id="bento-pipeline">
          <div className="pipeline-meta">
            <span><strong>11 phases</strong> · 3 consent gates · 1 swarm fork · 1 retry arc</span>
            <span>fig 01 · pipeline subway</span>
          </div>
          <PipelineSubway inset />
          <PipelineSubwayMobile />
        </div>

        <div className="bento-cell">
          <p className="stat-label">Commands</p>
          <p className="stat-num">4</p>
          <p className="stat-sub">all consent gates</p>
        </div>
        <div className="bento-cell">
          <p className="stat-label">MCP servers</p>
          <p className="stat-num">3</p>
          <p className="stat-sub"><code>context7</code> · <code>plantuml</code> · <code>playwright</code></p>
        </div>
        <div className="bento-cell">
          <p className="stat-label">Memory files</p>
          <p className="stat-num">6</p>
          <p className="stat-sub">+ <code>_pending.md</code></p>
        </div>
      </div>

      <div className="cta-row">
        <a href="#adoption" className="cta primary">Adopt baseline →</a>
        <a href="https://docs.claude.com/claude-code" target="_blank" rel="noopener" className="cta secondary">
          Claude Code docs <span className="vh">(opens in new tab)</span>
        </a>
      </div>
    </div>
  );
}

