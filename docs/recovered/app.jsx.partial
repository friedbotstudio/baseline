// ============================================================ § 03 MEMORY ============================================================
// Mobile vertical memory flow: 4 stages stacked vertically, then 6 canonical
// files in a 2-col grid below. Verify-on-read drawn as a small dashed loop on
// the right margin from the file block back up to /memory-flush.
function MemoryFlowPlateMobile() {
  return (
    <figure className="plate plate-mobile-only" aria-label="Memory data flow (mobile vertical)">
      <svg className="memory-flow-svg-mobile" viewBox="0 0 320 580" xmlns="http://www.w3.org/2000/svg">
        <defs>
          <marker id="mem-arr-m" viewBox="0 0 8 8" refX="7" refY="4" markerWidth="5" markerHeight="5" orient="auto">
            <path d="M0 0 L8 4 L0 8 z" fill="var(--color-charcoal)" />
          </marker>
          <marker id="mem-arr-m-dim" viewBox="0 0 8 8" refX="7" refY="4" markerWidth="5" markerHeight="5" orient="auto">
            <path d="M0 0 L8 4 L0 8 z" fill="var(--color-ash)" />
          </marker>
        </defs>

        {/* Stage 1 — Each turn */}
        <text x={160} y={20} textAnchor="middle"
              fontFamily="ui-monospace, monospace"
              fontSize="9" fontWeight="600" fill="var(--color-ash)"
              letterSpacing="0.06em">
          TRANSCRIPT
        </text>
        <rect x={70} y={28} width={180} height={36} rx="4"
              fill="var(--color-cream)" stroke="var(--color-charcoal)" strokeWidth="1" strokeDasharray="3 2" />
        <text x={160} y={51} textAnchor="middle"
              fontFamily="ui-monospace, monospace"
              fontSize="11.5" fontWeight="600" fill="var(--color-ink)">
          Each turn
        </text>
        <line x1={160} y1={64} x2={160} y2={84}
              stroke="var(--color-charcoal)" strokeWidth="1" markerEnd="url(#mem-arr-m)" />

        {/* Stage 2 — memory_stop */}
        <text x={160} y={98} textAnchor="middle"
              fontFamily="ui-monospace, monospace"
              fontSize="9" fontWeight="600" fill="var(--color-ash)"
              letterSpacing="0.06em">
          STOP HOOK
        </text>
        <rect x={70} y={106} width={180} height={32} rx="4"
              fill="var(--color-paper)" stroke="var(--color-charcoal)" strokeWidth="1" />
        <text x={160} y={127} textAnchor="middle"
              fontFamily="ui-monospace, monospace"
              fontSize="12" fontWeight="700" fill="var(--color-ink)">
          memory_stop
        </text>
        <line x1={160} y1={138} x2={160} y2={158}
              stroke="var(--color-charcoal)" strokeWidth="1" markerEnd="url(#mem-arr-m)" />

        {/* Stage 3 — _pending.md */}
        <text x={160} y={172} textAnchor="middle"
              fontFamily="ui-monospace, monospace"
              fontSize="9" fontWeight="600" fill="var(--color-ash)"
              letterSpacing="0.06em">
          GITIGNORED
        </text>
        <rect x={70} y={180} width={180} height={32} rx="4"
              fill="var(--color-paper)" stroke="var(--color-charcoal)" strokeWidth="1" />
        <text x={160} y={201} textAnchor="middle"
              fontFamily="ui-monospace, monospace"
              fontSize="12" fontWeight="700" fill="var(--color-ink)">
          _pending.md
        </text>
        <line x1={160} y1={212} x2={160} y2={232}
              stroke="var(--color-charcoal)" strokeWidth="1" markerEnd="url(#mem-arr-m)" />

        {/* Stage 4 — /memory-flush (accent — human curates) */}
        <text x={160} y={246} textAnchor="middle"
              fontFamily="ui-monospace, monospace"
              fontSize="9" fontWeight="700" fill="var(--color-accent-dark)"
              letterSpacing="0.06em">
          HUMAN CURATES
        </text>
        <rect x={70} y={254} width={180} height={32} rx="4"
              fill="var(--color-paper)" stroke="var(--color-accent-dark)" strokeWidth="1.4" />
        <text x={160} y={275} textAnchor="middle"
              fontFamily="ui-monospace, monospace"
              fontSize="12" fontWeight="700" fill="var(--color-accent-dark)">
          /memory-flush
        </text>

        {/* Trunk down to 6 canonical files */}
        <line x1={160} y1={286} x2={160} y2={310}
              stroke="var(--color-charcoal)" strokeWidth="1" />

        {/* 6 canonical files in 2-col grid (3 rows × 2 cols) */}
        {[
          { x:  20, y: 320, name: "landmarks.md" },
          { x: 170, y: 320, name: "libraries.md" },
          { x:  20, y: 360, name: "decisions.md" },
          { x: 170, y: 360, name: "landmines.md" },
          { x:  20, y: 400, name: "conventions.md" },
          { x: 170, y: 400, name: "pending-questions.md" },
        ].map((f) => (
          <g key={f.name}>
            <rect x={f.x} y={f.y} width={130} height={28} rx="3"
                  fill="var(--color-paper)" stroke="var(--color-charcoal)" strokeWidth="1" />
            <text x={f.x + 65} y={f.y + 18} textAnchor="middle"
                  fontFamily="ui-monospace, monospace"
                  fontSize="10" fontWeight="500" fill="var(--color-ink)">
              {f.name}
            </text>
          </g>
        ))}

        {/* Distribution lines from trunk to each file (top-row only, simplified) */}
        <line x1={85} y1={310} x2={85} y2={320}
              stroke="var(--color-charcoal)" strokeWidth="1" markerEnd="url(#mem-arr-m)" />
        <line x1={235} y1={310} x2={235} y2={320}
              stroke="var(--color-charcoal)" strokeWidth="1" markerEnd="url(#mem-arr-m)" />
        <line x1={20} y1={310} x2={300} y2={310}
              stroke="var(--color-charcoal)" strokeWidth="1" />
        <line x1={20} y1={310} x2={20} y2={300}
              stroke="var(--color-charcoal)" strokeWidth="0" />
        <line x1={160} y1={300} x2={160} y2={310}
              stroke="var(--color-charcoal)" strokeWidth="1" />

        {/* Verify-on-read feedback: dashed loop from the file block right side back up to /memory-flush */}
        <path d="M 295 414 Q 320 350, 270 270"
              fill="none"
              stroke="var(--color-ash)"
              strokeWidth="1"
              strokeDasharray="3 3"
              markerEnd="url(#mem-arr-m-dim)" />
        <text x={160} y={460} textAnchor="middle"
              fontFamily="ui-monospace, monospace"
              fontSize="10" fontWeight="500" fill="var(--color-ash)"
              letterSpacing="0.04em">
          verify on read
        </text>
        <text x={160} y={476} textAnchor="middle"
              fontFamily="ui-monospace, monospace"
              fontSize="10" fontWeight="500" fill="var(--color-ash)"
              letterSpacing="0.04em">
          correct or delete
        </text>
      </svg>
      <figcaption className="plate-caption">
        <strong>Fig. 06</strong>
        Auto-extract on Stop. Promote via <code>/memory-flush</code>. Verify-on-read keeps stale out of citations.
      </figcaption>
    </figure>
  );
}

function MemoryFlowPlate() {
