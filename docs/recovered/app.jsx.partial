const HOOK_WRITE_BOUNDARY = [
  {
    head: "Pre Bash",
    count: 2,
    rows: ["destructive_cmd_guard", "git_commit_guard"],
  },
  {
    head: "Pre Write/Edit",
    count: 10,
    rows: [
      "setup_guard",
      "env_guard",
      "spec_approval_guard",
      "verify_pass_guard",
      "track_guard",
      "artifact_template_guard",
      "plantuml_syntax_guard",
      "spec_diagram_presence_guard",
      "swarm_boundary_guard",
      "tdd_order_guard",
    ],
  },
  {
    head: "Post Write/Edit",
    count: 2,
    rows: ["lint_runner", "test_runner"],
  },
];

const HOOK_LIFECYCLE = [
  { head: "Session Start", count: 1, rows: ["memory_session_start"] },
  { head: "Stop",          count: 1, rows: ["memory_stop"] },
];

function HookCol({ b }) {
  return (
    <div className="hook-col">
      <p className="hook-col-head">
        <span>{b.head}</span>
        <span className="count">{b.count}</span>
      </p>
      {b.rows.map((r) => (
        <div className="hook-row" key={r}>{r.replace(/_/g, "_​")}</div>
      ))}
    </div>
  );
}

function HookBoundaryGrid() {
  return (
    <figure className="plate" aria-label="The 16 hooks placed at the tool-use boundary they fire on">
      <div className="hook-grid">
        <div className="hook-band">
          <p className="hook-band-eyebrow">
            <span>Write boundary</span>
            <span className="count">14 hooks</span>
          </p>
          <div className="hook-band-cols hook-band-cols-3">
            {HOOK_WRITE_BOUNDARY.map((b) => <HookCol key={b.head} b={b} />)}
          </div>
        </div>
        <div className="hook-band">
          <p className="hook-band-eyebrow">
            <span>Lifecycle</span>
            <span className="count">2 hooks</span>
          </p>
          <div className="hook-band-cols hook-band-cols-2">
            {HOOK_LIFECYCLE.map((b) => <HookCol key={b.head} b={b} />)}
          </div>
        </div>
      </div>
      <figcaption className="plate-caption">
        <strong>Fig. 03</strong>
        16 hooks placed at the boundary each fires on.
      </figcaption>
    </figure>
  );
}

const SKILL_CATEGORIES = [
  { name: "Artifact",      count: 4,  items: ["intake", "brd", "spec", "rca"] },
  { name: "Workflow",      count: 10, items: ["triage", "scout", "research", "tdd", "simplify", "security", "integrate", "document", "archive", "commit"] },
  { name: "Phase worker",  count: 5,  items: ["scenario", "implement", "verify", "prose", "design-ui"] },
  { name: "Spec helper",   count: 4,  items: ["spec-lint", "spec-render", "spec-diagram-review", "spec-traceability-review"] },
  { name: "Orchestration", count: 3,  items: ["harness", "swarm-plan", "swarm-dispatch"] },
  { name: "Memory",        count: 1,  items: ["memory-flush"] },
  { name: "Shared global", count: 7,  items: ["code-structure", "impeccable", "copywriting", "humanizer", "documentation", "technical-tutorials", "claude-automation-recommender"] },
  { name: "Audit",         count: 1,  items: ["audit-baseline"] },
];

function SkillCatalog() {
  return (
    <figure className="plate" aria-label="35 skills grouped by category">
      <div className="skill-catalog">
        {SKILL_CATEGORIES.map((c) => (
          <div className="skill-cat" key={c.name}>
            <div className="skill-cat-head">
              <span className="skill-cat-name">{c.name}</span>
              <span className="skill-cat-count">{c.count}</span>
            </div>
            <div className="skill-cat-list">
              {c.items.map((it) => (
                <span className="pill" key={it}>{it}</span>
              ))}
            </div>
          </div>
        ))}
      </div>
      <figcaption className="plate-caption">
        <strong>Fig. 04</strong>
        35 skills across 8 categories. Five mandate composition with another (see fig. 02).
      </figcaption>
    </figure>
  );
}

