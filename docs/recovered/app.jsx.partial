// ============================================================ § 04 ADOPTION ============================================================
// Install plate is rendered as a dev-window — mac traffic-light dots, filename
// in mono, dark slate body. This is the page's dev-craft moment per the
// phantomflow pattern.
function DevWindow({ filename, code, copyText }) {
  return (
    <div className="dev-window">
      <div className="dev-window-chrome">
        <div className="dev-window-dots" aria-hidden="true">
          <span className="dot r" />
          <span className="dot y" />
          <span className="dot g" />
        </div>
        <span className="dev-window-filename">{filename}</span>
      </div>
      <pre aria-label="Install command">{code}</pre>
      <CopyButton text={copyText} />
    </div>
  );
}

