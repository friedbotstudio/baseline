        ].map((f) => (
          <g key={f.name}>
            <rect x={f.x} y={f.y} width={130} height={32} rx="3"
                  fill="var(--color-paper)" stroke="var(--color-charcoal)" strokeWidth="1" />
            <text x={f.x + 65} y={f.y + 20} textAnchor="middle"
                  fontFamily="ui-monospace, monospace"
                  fontSize="10.5" fontWeight="600" fill="var(--color-ink)">
              {f.name}
            </text>
          </g>
        ))}

        <path d="M 585 95 V 130 H 270 V 145"
              fill="none" stroke="var(--color-charcoal)" strokeWidth="1" />
        {[125, 265, 405].map((x) => (
          <line key={`down-top-${x}`} x1={x} y1="145" x2={x} y2="165"
                stroke="var(--color-charcoal)" strokeWidth="1" markerEnd="url(#mem-arr)" />
        ))}
        {[125, 265, 405].map((x) => (
          <line key={`down-bot-${x}`} x1={x} y1="195" x2={x} y2="215"
                stroke="var(--color-charcoal)" strokeWidth="1" markerEnd="url(#mem-arr)" />
        ))}

        <path d="M 470 231 Q 540 240, 600 165"
              fill="none"
              stroke="var(--color-ash)"
              strokeWidth="1"
              strokeDasharray="3 3"
              markerEnd="url(#mem-arr-dim)" />
        <text x="555" y="260" textAnchor="middle"
              fontFamily="ui-monospace, monospace"
              fontSize="9" fontWeight="500" fill="var(--color-ash)" letterSpacing="0.06em">
          verify on read · correct or delete
        </text>
      </svg>
      <figcaption className="plate-caption">
        <strong>Fig. 06</strong>
        Auto-extract on Stop. Promote via <code>/memory-flush</code>. Verify-on-read keeps stale out of citations.
      </figcaption>
    </figure>
  );
}

